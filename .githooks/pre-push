#!/bin/sh
set -e

echo "=== Running Pre-Push Hooks ==="

echo "1. Checking code formatting (cargo fmt)..."
cargo fmt --all -- --check

echo "2. Running Clippy lints (cargo clippy)..."
cargo clippy --all-targets -- -D warnings

echo "3. Linting WebUI (next lint)..."
(cd webui && npm run lint)

echo "4. Running tests (cargo test --workspace)..."
cargo test --workspace

echo "=== All pre-push checks passed successfully! ==="
